# ====================================================================
# Tomorrow World – Yacht Booking System
# Copy this file to `.env` (local) or add to Render / Railway env vars.
# NEVER commit your real .env file.
# ====================================================================

# Flask
SECRET_KEY=change-me-to-a-long-random-string
INIT_ADMIN_PASSWORD=Admin@123     # the first-run admin password – change immediately

# Database (leave empty for local SQLite)
DATABASE_URL=

# Email – Gmail SMTP with App Password
# 1. Turn on 2-Step Verification for your Google account
#    https://myaccount.google.com/security
# 2. Generate an App Password (select "Mail" / "Other")
#    https://myaccount.google.com/apppasswords
# 3. Paste the 16-character App Password (no spaces) into MAIL_PASSWORD below.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-shared-mailbox@gmail.com
MAIL_PASSWORD=xxxxxxxxxxxxxxxx
MAIL_DEFAULT_SENDER=Tomorrow World <your-shared-mailbox@gmail.com>

# The inbox that will receive "new booking" and "cancellation" notifications
ADMIN_EMAIL=admin@tomorrowworld.com
